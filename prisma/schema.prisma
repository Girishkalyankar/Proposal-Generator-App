generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  password      String?
  emailVerified DateTime?
  image         String?
  isActivated   Boolean      @default(false)
  isAdmin       Boolean      @default(false)
  accounts      Account[]
  sessions      Session[]
  proposals     Proposal[]
  templates     Template[]
  accessCode    AccessCode?  @relation("UsedBy")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AccessCode {
  id         String    @id @default(cuid())
  code       String    @unique
  label      String?
  isUsed     Boolean   @default(false)
  usedById   String?   @unique
  usedBy     User?     @relation("UsedBy", fields: [usedById], references: [id])
  usedAt     DateTime?
  revoked    Boolean   @default(false)
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Proposal {
  id            String            @id @default(cuid())
  title         String
  clientName    String?
  clientEmail   String?
  status        ProposalStatus    @default(DRAFT)
  shareToken    String?           @unique @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections      ProposalSection[]
  viewedAt      DateTime?
  sentAt        DateTime?
  totalValue    Decimal?          @db.Decimal(12, 2)
  deletedAt     DateTime?
  lastEditedBy  String?
  lastEditedAt  DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
}

model ProposalSection {
  id         String      @id @default(cuid())
  proposalId String
  proposal   Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  type       SectionType
  title      String
  content    Json
  order      Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([proposalId])
}

enum SectionType {
  COVER
  SUMMARY
  PROBLEM
  SOLUTION
  PRICING
  TIMELINE
  TEAM
  TERMS
  CONTACT
  CUSTOM
}

model Template {
  id          String            @id @default(cuid())
  name        String
  description String?
  category    String?
  isPublic    Boolean           @default(false)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections    TemplateSection[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
}

model TemplateSection {
  id         String      @id @default(cuid())
  templateId String
  template   Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type       SectionType
  title      String
  content    Json
  order      Int

  @@index([templateId])
}
